{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self'; manifest-src 'self'; worker-src 'self'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'"},
        {"key": "X-Content-Type-Options", "value": "nosniff"},
        {"key": "Referrer-Policy", "value": "no-referrer"}
      ]
    }
  ],
  "rewrites": [
    {"source": "/risk/", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/risk/"},
    {"source": "/risk/:path*", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/risk/:path*"},
    {"source": "/cycles/", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/cycles/"},
    {"source": "/cycles/:path*", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/cycles/:path*"},
    {"source": "/frequency/", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/frequency/"},
    {"source": "/frequency/:path*", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/frequency/:path*"},
    {"source": "/merit-order/", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/merit-order/"},
    {"source": "/merit-order/:path*", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/merit-order/:path*"},
    {"source": "/intraday/", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/intraday/"},
    {"source": "/intraday/:path*", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/intraday/:path*"},
    {"source": "/icons/", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/icons/"},
    {"source": "/icons/:path*", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/icons/:path*"},
    {"source": "/", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/"},
    {"source": "/sw.js", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/sw.js"},
    {"source": "/manifest.webmanifest", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/energy/manifest.webmanifest"},
    {"source": "/", "destination": "/home/"},
    {"source": "/sw.js", "destination": "/home/sw.js"},
    {"source": "/manifest.webmanifest", "destination": "/home/manifest.webmanifest"}
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "fermi.matthewgarner.me" }],
      "destination": "https://tools.matthewgarner.me/fermi/:path*",
      "permanent": true
    },
    {
      "source": "/energy/",
      "has": [{"type": "host", "value": "tools.matthewgarner.me"}],
      "destination": "https://energy.matthewgarner.me/",
      "permanent": false
    },
    {
      "source": "/energy/:path*",
      "has": [{"type": "host", "value": "tools.matthewgarner.me"}],
      "destination": "https://energy.matthewgarner.me/:path*",
      "permanent": false
    },
    {"source": "/risk", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/risk/", "permanent": false},
    {"source": "/cycles", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/cycles/", "permanent": false},
    {"source": "/frequency", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/frequency/", "permanent": false},
    {"source": "/merit-order", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/merit-order/", "permanent": false},
    {"source": "/intraday", "has": [{"type": "host", "value": "energy.matthewgarner.me"}], "destination": "/intraday/", "permanent": false}
  ]
}
